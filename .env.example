# ──────────────────────────────────────────────────────────────────────────────
#  Copy this file to .env.local and fill in your values.
#  .env.local is gitignored — never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string  (required)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/compliance_db

# JWT signing secret — also used as the SMTP password encryption key  (required)
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex_string

# Disable Next.js telemetry  (optional but recommended)
NEXT_TELEMETRY_DISABLED=1
